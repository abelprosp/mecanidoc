# Copiar para .env na raiz do projeto (não fazer commit do .env).
#
# Scripts no host (npm run seed:*, import:*, etc.): use localhost + porta publicada.
# docker compose up → porta 5432
# docker compose -f docker-compose.dev.yml up → porta 5433
DATABASE_URL=postgresql://mecanidoc:mecanidoc@localhost:5432/mecanidoc
#
# Dentro do contentor app (docker-compose.yml) o serviço usa hostname "postgres"
# automaticamente — não copie isso para o .env do host.
#
AUTH_SECRET=change-me-use-openssl-rand-hex-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
