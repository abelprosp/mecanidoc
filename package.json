{
  "name": "mecanidoc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.js dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && node scripts/run-next.js dev",
    "dev:next": "next dev",
    "build": "node scripts/run-next.js build",
    "start": "next start",
    "lint": "eslint",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "mirror-images": "node scripts/mirror-product-images.mjs",
    "mirror-images:dry": "node scripts/mirror-product-images.mjs --dry-run",
    "db:schema": "node scripts/build-docker-schema.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:postgres": "docker compose up postgres -d",
    "seed:na-example": "node scripts/seed-neumaticos-andres-example.mjs",
    "seed:brand-logos": "node scripts/seed-brand-logos.mjs",
    "seed:brand-logos:vps": "bash scripts/vps-import.sh seed-brand-logos.mjs",
    "import:na-products": "node scripts/import-na-products.mjs",
    "import:na-catalog": "node scripts/import-na-catalog.mjs",
    "import:na-auto": "node scripts/import-na-auto.mjs",
    "import:na-moto": "node scripts/import-na-moto.mjs",
    "import:na-camion": "node scripts/import-na-camion.mjs",
    "import:na-tracteur": "node scripts/import-na-tracteur.mjs",
    "import:na-auto:vps": "bash scripts/vps-import.sh import-na-auto.mjs",
    "import:na-moto:vps": "bash scripts/vps-import.sh import-na-moto.mjs",
    "import:na-camion:vps": "bash scripts/vps-import.sh import-na-camion.mjs",
    "import:na-tracteur:vps": "bash scripts/vps-import.sh import-na-tracteur.mjs",
    "enrich:products:vps": "bash scripts/vps-import.sh enrich-products.mjs",
    "fix:product-names": "node scripts/fix-product-names.mjs",
    "fix:product-names:vps": "bash scripts/vps-import.sh fix-product-names.mjs",
    "enrich:eprel": "node scripts/enrich-eprel.mjs",
    "enrich:eprel:vps": "bash scripts/vps-import.sh enrich-eprel.mjs",
    "enrich:catalog": "node scripts/enrich-catalog.mjs",
    "enrich:catalog:vps": "bash scripts/vps-import.sh enrich-catalog.mjs",
    "enrich:generic": "node scripts/enrich-catalog.mjs --supplier=neumaticos_andres --generic-only --skip-upc",
    "enrich:generic:vps": "bash scripts/vps-import.sh enrich-catalog.mjs --supplier=neumaticos_andres --generic-only --skip-upc",
    "enrich:eprel": "node scripts/enrich-catalog.mjs --supplier=neumaticos_andres --generic-only --skip-upc --skip-gtinhub",
    "enrich:eprel:vps": "bash scripts/vps-import.sh enrich-catalog.mjs --supplier=neumaticos_andres --generic-only --skip-upc --skip-gtinhub",
    "probe:gtinhub": "node scripts/probe-gtinhub.mjs",
    "probe:gtinhub:vps": "bash scripts/vps-import.sh probe-gtinhub.mjs",
    "probe:product-name": "node scripts/probe-product-name.mjs",
    "fetch:na-images": "node scripts/fetch-na-product-images.mjs",
    "fetch:eprel-images": "node scripts/fetch-eprel-images.mjs",
    "enrich:products": "node scripts/enrich-products.mjs"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.10.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "imapflow": "^1.2.13",
    "jose": "^6.2.3",
    "lucide-react": "^0.562.0",
    "mailparser": "^3.9.4",
    "next": "16.1.4",
    "nodemailer": "^8.0.2",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "ssh2-sftp-client": "^12.1.1",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2-sftp-client": "^9.0.6",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
