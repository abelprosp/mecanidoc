    "enrich:products": "node scripts/enrich-products.mjs"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.10.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "imapflow": "^1.2.13",
    "jose": "^6.2.3",
    "lucide-react": "^0.562.0",
    "mailparser": "^3.9.4",
    "next": "16.1.4",
    "nodemailer": "^8.0.2",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "ssh2-sftp-client": "^12.1.1",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2-sftp-client": "^9.0.6",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
